# Hansetu Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# Database
# Neon (default):
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# AWS RDS example:
# DATABASE_URL=postgresql://user:password@mydb.cluster-xxx.us-east-1.rds.amazonaws.com:5432/hansetu?sslmode=require

# Supabase example:
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Auth
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# GST Verification (WhiteBooks)
WHITEBOOKS_GST_API_URL=https://apisandbox.whitebooks.in/public/search
WHITEBOOKS_GST_EMAIL=your-email@example.com
WHITEBOOKS_CLIENT_ID=your_whitebooks_client_id
WHITEBOOKS_CLIENT_SECRET=your_whitebooks_client_secret

# CORS
FRONTEND_URL=http://localhost:5173

# Provider Migration (only needed when migrating between providers)
# SOURCE_DB_URL=postgresql://user:pass@neon-host/neondb?sslmode=require
# TARGET_DB_URL=postgresql://user:pass@aws-rds-host/hansetu?sslmode=require
