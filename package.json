{
  "name": "hansetu-backend",
  "version": "1.0.0",
  "description": "Hansetu Backend - Modular Monolith Architecture",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node-dev --transpile-only src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "ts-node-dev --transpile-only src/db/seeds/index.ts",
    "db:studio": "drizzle-kit studio",
    "db:export": "bash scripts/db-export.sh",
    "db:import": "bash scripts/db-import.sh",
    "migrate:provider": "ts-node-dev --transpile-only scripts/migrate-provider.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "nodemon": "^3.1.14",
    "pg": "^8.11.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "drizzle-kit": "^0.30.4",
    "eslint": "^8.57.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
